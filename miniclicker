<body>
    <div class="header">
        <h1 id="user-name">Загрузка...</h1>
    </div>

    <div class="balance-container">
        <div class="balance-label">БАЛАНС (BTC)</div>
        <div id="balance-display">0</div>
        <div class="income-per-second" id="income-per-second">+0 BTC/сек</div>
    </div>

    <div class="tabs">
        <button class="tab-btn active" data-tab="farm-tab">🎮 Ферма</button>
        <button class="tab-btn" data-tab="shop-tab">🛒 Магазин</button>
    </div>

    <div id="farm-tab" class="tab-content active">
        <h2 class="farm-title">МАЙНИНГ ФЕРМА</h2>
        
        <div class="farm-stats">
            <h3>СТАТИСТИКА</h3>
            <div class="stats-grid">
                <div class="stat-item">
                    <div>Всего карт</div>
                    <div class="stat-value" id="total-cards">0</div>
                </div>
                <div class="stat-item">
                    <div>Мощность</div>
                    <div class="stat-value" id="total-power">0 MH/s</div>
                </div>
            </div>
        </div>

        <div class="mine-btn" id="mine-btn" onclick="manualMine()">
            ⛏️
        </div>
        <p style="color: #aaa; margin-top: 10px;">Нажми для ручного майнинга</p>
    </div>

    <div id="shop-tab" class="tab-content">
        <h2 class="shop-title">МАГАЗИН ВИДЕОКАРТ</h2>
        <div class="cards-grid" id="cards-container">
            <!-- Карточки будут генерироваться через JS -->
        </div>
    </div>

    <script>
        // ========== ИНИЦИАЛИЗАЦИЯ TELEGRAM ==========
        const tg = window.Telegram?.WebApp;
        let userName = 'Гость';
        
        if (tg) {
            tg.expand();
            userName = tg.initDataUnsafe?.user?.first_name || 'Гость';
        }
        
        document.getElementById('user-name').textContent = `👤 ${userName}`;

        // ========== КОНСТАНТЫ ИГРЫ ==========
        const MINING_CARDS = [
            { id: 0, name: "GTX 1050", basePrice: 10, income: 1 },
            { id: 1, name: "GTX 1060", basePrice: 50, income: 5 },
            { id: 2, name: "GTX 1070", basePrice: 200, income: 20 },
            { id: 3, name: "GTX 1080", basePrice: 1000, income: 100 },
            { id: 4, name: "RTX 3060", basePrice: 5000, income: 500 },
            { id: 5, name: "RTX 3070", basePrice: 25000, income: 2500 },
            { id: 6, name: "RTX 4080", basePrice: 100000, income: 10000 },
            { id: 7, name: "RTX 4090", basePrice: 500000, income: 50000 }
        ];

        // ========== СОСТОЯНИЕ ИГРЫ ==========
        let gameState = {
            balance: 0,
            cards: {},
            totalIncome: 0
        };

        // ========== ЗАГРУЗКА СОХРАНЕНИЙ ==========
        function loadGameState() {
            const savedBalance = localStorage.getItem('mining_farm_balance');
            const savedCards = localStorage.getItem('mining_farm_cards');
            
            if (savedBalance) {
                gameState.balance = parseFloat(savedBalance);
            }
            
            if (savedCards) {
                gameState.cards = JSON.parse(savedCards);
            }
            
            calculateTotalIncome();
        }

        // ========== СОХРАНЕНИЕ ИГРЫ ==========
        function saveGameState() {
            localStorage.setItem('mining_farm_balance', gameState.balance.toString());
            localStorage.setItem('mining_farm_cards', JSON.stringify(gameState.cards));
        }

        // ========== РАСЧЕТ ДОХОДА ==========
        function calculateTotalIncome() {
            gameState.totalIncome = 0;
            Object.keys(gameState.cards).forEach(cardId => {
                const card = MINING_CARDS.find(c => c.id === parseInt(cardId));
                if (card) {
                    gameState.totalIncome += card.income * gameState.cards[cardId];
                }
            });
        }

        // ========== ОБНОВЛЕНИЕ ИНТЕРФЕЙСА ==========
        function updateUI() {
            // Баланс
            document.getElementById('balance-display').textContent = 
                gameState.balance.toFixed(2);
            
            // Доход в секунду
            document.getElementById('income-per-second').textContent = 
                `+${gameState.totalIncome.toFixed(2)} BTC/сек`;
            
            // Общая статистика
            const totalCards = Object.values(gameState.cards).reduce((sum, count) => sum + count, 0);
            document.getElementById('total-cards').textContent = totalCards;
            document.getElementById('total-power').textContent = `${(gameState.totalIncome * 10).toFixed(0)} MH/s`;
            
            // Обновление карточек в магазине
            updateShopCards();
        }

        // ========== ОБНОВЛЕНИЕ КАРТОЧЕК МАГАЗИНА ==========
        function updateShopCards() {
            const container = document.getElementById('cards-container');
            container.innerHTML = '';
            
            MINING_CARDS.forEach(card => {
                const ownedCount = gameState.cards[card.id] || 0;
                const price = Math.floor(card.basePrice * Math.pow(1.5, ownedCount));
                const canAfford = gameState.balance >= price;
                
                const cardElement = document.createElement('div');
                cardElement.className = 'card';
                cardElement.innerHTML = `
                    <div class="card-header">
                        <div class="card-name">${card.name}</div>
                        <div class="card-income">+${card.income.toFixed(2)} BTC/сек</div>
                    </div>
                    <div class="card-price">
                        <div class="price-label">Цена:</div>
                        <div class="price-value">${price.toFixed(2)} BTC</div>
                    </div>
                    <button class="buy-btn" onclick="buyCard(${card.id})" 
                            ${!canAfford ? 'disabled' : ''}>
                        КУПИТЬ
                    </button>
                    <div class="card-owned">В наличии: ${ownedCount}</div>
                `;
                
                container.appendChild(cardElement);
            });
        }

        // ========== ПОКУПКА КАРТОЧКИ ==========
        function buyCard(cardId) {
            const card = MINING_CARDS.find(c => c.id === cardId);
            if (!card) return;
            
            const ownedCount = gameState.cards[cardId] || 0;
            const price = Math.floor(card.basePrice * Math.pow(1.5, ownedCount));
            
            if (gameState.balance >= price) {
                gameState.balance -= price;
                gameState.cards[cardId] = (gameState.cards[cardId] || 0) + 1;
                
                calculateTotalIncome();
                updateUI();
                saveGameState();
                
                // Тактильный отклик в Telegram
                if (tg?.HapticFeedback) {
                    tg.HapticFeedback.impactOccurred('medium');
                }
                
                // Визуальная обратная связь
                const btn = event.target;
                btn.style.backgroundColor = '#4CAF50';
                setTimeout(() => {
                    btn.style.backgroundColor = '';
                }, 300);
            }
        }

        // ========== РУЧНОЙ МАЙНИНГ ==========
        function manualMine() {
            gameState.balance += 1;
            updateUI();
            saveGameState();
            
            // Тактильный отклик в Telegram
            if (tg?.HapticFeedback) {
                tg.HapticFeedback.impactOccurred('light');
            }
            
            // Анимация кнопки
            const btn = document.getElementById('mine-btn');
            btn.style.transform = 'scale(0.95)';
            btn.style.boxShadow = '0 0 30px rgba(255, 235, 59, 0.8)';
            
            setTimeout(() => {
                btn.style.transform = '';
                btn.style.boxShadow = '';
            }, 200);
        }

        // ========== АВТОМАТИЧЕСКИЙ МАЙНИНГ ==========
        function autoMine() {
            gameState.balance += gameState.totalIncome;
            updateUI();
            saveGameState();
        }

        // ========== ПЕРЕКЛЮЧЕНИЕ ВКЛАДОК ==========
        function setupTabs() {
            const tabBtns = document.querySelectorAll('.tab-btn');
            const tabContents = document.querySelectorAll('.tab-content');
            
            tabBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const tabId = btn.getAttribute('data-tab');
                    
                    // Убираем активный класс у всех кнопок и контента
                    tabBtns.forEach(b => b.classList.remove('active'));
                    tabContents.forEach(c => c.classList.remove('active'));
                    
                    // Добавляем активный класс выбранным
                    btn.classList.add('active');
                    document.getElementById(tabId).classList.add('active');
                });
            });
        }

        // ========== ИНИЦИАЛИЗАЦИЯ ИГРЫ ==========
        function initGame() {
            loadGameState();
            updateUI();
            setupTabs();
            
            // Запускаем автоматический майнинг каждую секунду
            setInterval(autoMine, 1000);
            
            // Автосохранение каждые 30 секунд
            setInterval(saveGameState, 30000);
            
            console.log('Майнинг ферма загружена!');
        }

        // ========== ЗАПУСК ИГРЫ ПРИ ЗАГРУЗКЕ ==========
        document.addEventListener('DOMContentLoaded', initGame);
    </script>
</body>
</html>
